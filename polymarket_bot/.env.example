# Keep paper mode on first
PAPER_MODE=true

# Risk settings
STARTING_BANKROLL=200
MAX_RISK_PER_TRADE_PCT=0.02
MAX_DAILY_DRAWDOWN_PCT=0.10
MAX_TRADES_PER_DAY=10
MIN_EDGE=0.04
MIN_PRICE=0.05
MAX_PRICE=0.85

# Optional: specific market id / slug filter
MARKET_FILTER=

# Polling seconds
LOOP_SECONDS=60

# Data API tuning
EVENT_LIMIT=100
HTTP_TIMEOUT_SECONDS=20
MAX_DAYS_TO_RESOLUTION=7
MAX_HOURS_TO_RESOLUTION=0
REQUIRE_STARTED=true

# CLOB SDK settings (for authenticated trading)
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
PRIVATE_KEY=
SIGNATURE_TYPE=0
FUNDER=
